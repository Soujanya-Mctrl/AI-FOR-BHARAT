{
  "expo": {
    "name": "EcoWaste",
    "slug": "ecowaste",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "ecowaste",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#16a34a"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundColor": "#16a34a"
      },
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ],
      "package": "com.ecowaste.app",
      "edgeToEdgeEnabled": true
    },
    "ios": {
      "bundleIdentifier": "com.ecowaste.app",
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "EcoWaste needs camera to photograph your waste for AI classification",
        "NSLocationWhenInUseUsageDescription": "EcoWaste needs your location to verify pickup and connect you with nearby kabadiwallas",
        "NSLocationAlwaysUsageDescription": "Kabadiwallas need background location for route tracking"
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      "expo-location",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#16a34a"
        }
      ],
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#16a34a"
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": false,
      "reactCompiler": true
    }
  }
}